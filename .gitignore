# ==========================================
# 1. Python Compiled Bytecode & Cache Files
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# 2. Package Management & Distribution (e.g., pip install, build tools)
# ==========================================
# Prevents egg-info folders generated by pip install -e .
*.egg-info/
.eggs/
build/
dist/
sdist/
wheels/
share/python-wheels/

# ==========================================
# 3. Virtual Environments & Local Dependencies
# ==========================================
# Blocks the local dependency environments from being pushed
.venv/
venv/
ENV/
env/
# For other environment tools (Pipenv, Poetry, etc.)
.pipenv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ==========================================
# 4. Application Runtime Data (JSON, Logs, SQLite)
# ==========================================
# Blocks dynamically generated text/JSON files and application logs
*.log
*.json
*.sqlite3

# ==========================================
# 5. OS & IDE Specific Configurations (Optional but Recommended)
# ==========================================
.DS_Store
.idea/
.vscode/
*.swp